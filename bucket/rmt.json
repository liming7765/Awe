{
    "version": "1.1",
    "description": "RMT (RuoMengTu) is a free, open-source macro tool built on AHKv2. Let the code handle the tedious work—you have more meaningful things to do.",
    "homepage": "https://github.com/zclucas/RMT",
    "license": "AGPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zclucas/RMT/releases/download/RMTv1.1/RMTv1.1_x64.zip",
            "hash": "7fa22956e32d2ccbda064f20d46ea09ea809f62a2b6e794cdb2ae05baa4d8f9f"
        },
        "32bit": {
            "url": "https://github.com/zclucas/RMT/releases/download/RMTv1.1/RMTv1.1_x32.zip",
            "hash": "065c097b24d55feb8dc037742179fe8a2196137fc046dea27e5c57e7f8e39e1c"
        }
    },
    "pre_install": [
        "Get-ChildItem \"$dir\\RMTv*.exe\" | Rename-Item -NewName 'RMT.exe' -ErrorAction SilentlyContinue",
        "if (!(Test-Path \"$dir\\SettingOld\")) { New-Item \"$dir\\SettingOld\" -Type Directory }"
    ],
    "bin": "RMT.exe",
    "shortcuts": [
        [
            "RMT.exe",
            "RMT"
        ]
    ],
    "persist": [
        "Setting",
        "SettingOld"
    ],
    "checkver": {
        "github": "https://github.com/zclucas/RMT",
        "regex": "RMTv([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zclucas/RMT/releases/download/RMTv$version/RMTv$version_x64.zip"
            },
            "32bit": {
                "url": "https://github.com/zclucas/RMT/releases/download/RMTv$version/RMTv$version_x32.zip"
            }
        }
    }
}
